    "semanticHighlighting": true,
    "tokenColors": [
        {
            "scope": [
                "keyword",
                "keyword.operator",
                "storage"
            ],
            "settings": {
                "foreground": "#F1AFF6"
            }
        },
        {
            "scope": [
                "comment"
            ],
            "settings": {
                "foreground": "#FFFFFF99"
            }
        },
        {
            "scope": [
                "constant.numeric"
            ],
            "settings": {
                "foreground": "#46EBE1"
            }
        },
        {
            "scope": [
                "string",
                "constant.character"
            ],
            "settings": {
                "foreground": "#D7FF64"
            }
        },
        {
            "scope": [
                "entity.name"
            ],
            "settings": {
                "foreground": "#DE5FE9"
            }
        },
        {
            "scope": [
                "entity.name.function"
            ],
            "settings": {
                "foreground": "#00F5D4"
            }
        },
        {
            "scope": [
                "variable",
                "constant"
            ],
            "settings": {
                "foreground": "#FFFFFF"
            }
        },
        {
            "scope": [
                "support"
            ],
            "settings": {
                "foreground": "#DE5FE9"
            }
        }
    ],
    "type": "dark"
