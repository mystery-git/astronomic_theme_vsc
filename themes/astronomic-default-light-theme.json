    "semanticHighlighting": true,
    "tokenColors": [
        {
            "scope": [
                "keyword",
                "storage"
            ],
            "settings": {
                "foreground": "#0092e1"
            }
        },
        {
            "scope": [
                "keyword.operator"
            ],
            "settings": {
                "foreground": "#0B060F"
            }
        },
        {
            "scope": [
                "comment"
            ],
            "settings": {
                "foreground": "#888888"
            }
        },
        {
            "scope": [
                "constant.numeric"
            ],
            "settings": {
                "foreground": "#e62a00"
            }
        },
        {
            "scope": [
                "string",
                "constant.character"
            ],
            "settings": {
                "foreground": "#0a900a"
            }
        },
        {
            "scope": [
                "entity.name"
            ],
            "settings": {
                "foreground": "#e819fb"
            }
        },
        {
            "scope": [
                "entity.name.function"
            ],
            "settings": {
                "foreground": "#8a25e3"
            }
        },
        {
            "scope": [
                "variable",
                "constant"
            ],
            "settings": {
                "foreground": "#0B060F"
            }
        },
        {
            "scope": [
                "support"
            ],
            "settings": {
                "foreground": "#e819fb"
            }
        }
    ],
    "type": "light"
